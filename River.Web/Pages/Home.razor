@page "/"
@using System.Globalization
@using System.Linq

<PageTitle>Przemiany zanieczyszczeń w rzece</PageTitle>

<div class="app-grid">

    @* ─── lewa kolumna: parametry + lista odcinków ───────────────────── *@
    <div class="app-left">
        <GlobalParamsPanel Vm="_globals"
                           CanRemove="_segments.Count > 0"
                           OnAdd="AddSegment"
                           OnRemove="RemoveSegment"
                           OnCompute="Compute" />

        <div class="segments-list">
            @for (int i = 0; i < _segments.Count; i++)
            {
                var idx = i;
                <SegmentEditor Vm="_segments[idx]"
                               Number="@(idx + 1)"
                               MaxOutletDelta="@(_segments.Count - (idx + 1))" />
            }
        </div>
    </div>

    @* ─── prawa kolumna: zakładki Wykres / Tekst / Info ─────────────── *@
    <div class="app-right">
        <MudTabs Elevation="1" Rounded="true" Class="full-tabs">
            <MudTabPanel Text="Wykres" Class="fill-panel">
                @if (_results.Count > 0)
                {
                    <PollutionChart Segments="_lastInputs" Results="_results" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        Dodaj co najmniej jeden odcinek i kliknij <b>Licz!</b>, aby zobaczyć wykres.
                    </MudText>
                }
            </MudTabPanel>

            <MudTabPanel Text="Tekst">
                <pre style="white-space: pre-wrap; font-family: 'Consolas', monospace; margin: 0;">@_textReport</pre>
            </MudTabPanel>

            <MudTabPanel Text="Info">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6">Program do celów dydaktycznych</MudText>
                    <MudText>Przemiany zanieczyszczeń w rzece</MudText>
                    <MudText>Instytut Inżynierii Ochrony Środowiska</MudText>
                    <MudText>Politechnika Wrocławska</MudText>
                </MudStack>
            </MudTabPanel>
        </MudTabs>
    </div>

</div>

<style>
    .app-grid {
        display: grid;
        grid-template-columns: minmax(440px, 480px) 1fr;
        gap: 12px;
        padding: 12px;
        /* MudAppBar = 68px; minus dolny padding ≈ 16px */
        height: calc(100vh - 84px);
        box-sizing: border-box;
    }
    .app-left {
        display: flex;
        flex-direction: column;
        gap: 8px;
        overflow: hidden;
    }
    .segments-list {
        flex: 1;
        overflow-y: auto;
        padding-right: 4px;
    }
    .app-right {
        height: 100%;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    /* Wymuszamy łańcuch flex w MudTabs aby panel zawartości wypełnił dostępną wysokość. */
    .app-right .full-tabs {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    .app-right .mud-tabs-panels {
        flex: 1;
        min-height: 0;
        display: flex;
    }
    .app-right .mud-tab-panel {
        flex: 1;
        min-height: 0;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    /* Plotly w środku panelu — pełna wysokość. */
    .app-right .plotly-graph-div,
    .app-right .js-plotly-plot {
        flex: 1;
        height: 100% !important;
        min-height: 0 !important;
    }
</style>

@code {
    private readonly GlobalParamsVm _globals = new();
    private readonly List<SegmentVm> _segments = new();

    private IReadOnlyList<SegmentInput> _lastInputs = Array.Empty<SegmentInput>();
    private IReadOnlyList<SegmentResult> _results = Array.Empty<SegmentResult>();
    private string _textReport = "";

    private void AddSegment()
    {
        _segments.Add(new SegmentVm());
    }

    private void RemoveSegment()
    {
        if (_segments.Count > 0)
        {
            _segments.RemoveAt(_segments.Count - 1);
            // Po usunięciu ostatniego odcinka skoryguj OutletTo, gdyby wskazywał poza listę.
            for (int i = 0; i < _segments.Count; i++)
            {
                int max = _segments.Count - (i + 1);
                if (_segments[i].OutletTo > max) _segments[i].OutletTo = 0;
            }
        }
    }

    private void Compute()
    {
        var globals = _globals.ToRecord();
        var inputs = _segments.Select(s => s.ToRecord()).ToArray();
        var results = RiverModel.Compute(globals, inputs);

        _lastInputs = inputs;
        _results = results;
        // Tekstowy raport — w UI wygodniej z kropkami (InvariantCulture).
        _textReport = TextReport.Build(globals, inputs, results, CultureInfo.InvariantCulture);
    }
}
