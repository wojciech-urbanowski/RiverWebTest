@* Kompaktowy wiersz: etykieta nad polem + jednostka po prawej. *@

<MudStack Spacing="0">
    <MudText Typo="Typo.caption">@Label</MudText>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudNumericField T="double"
                         Value="Value"
                         ValueChanged="ValueChanged"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Immediate="true"
                         HideSpinButtons="true"
                         Disabled="Disabled"
                         Style="max-width: 110px" />
        <MudText Typo="Typo.body2" Style="@($"white-space: nowrap;{(Disabled ? "opacity: 0.5" : "")}")">@Unit</MudText>
    </MudStack>
</MudStack>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Unit { get; set; } = "";
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
}
